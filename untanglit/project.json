{
  "name": "untanglit",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/.next"],
      "configurations": {
        "production": {}
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next dev",
        "cwd": "{projectRoot}"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next start",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint .",
        "cwd": "{projectRoot}"
      }
    }
  }
}
