# App URL (used for Stripe success/cancel redirects and metadata)
# In production set to your domain, e.g. https://untanglit.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe – required for subscription checkout
# Get your keys from https://dashboard.stripe.com/apikeys
# Create a Product; add a $99/month recurring Price (STRIPE_PRICE_ID_MONTHLY) and a $990/year recurring Price (STRIPE_PRICE_ID_YEARLY)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
