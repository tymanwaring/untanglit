{
  "name": "primo-plumbing",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/.next"],
      "configurations": { "production": {} }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next dev -p 3003",
        "cwd": "{projectRoot}"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx next start -p 3003",
        "cwd": "{projectRoot}"
      }
    }
  }
}
